{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/design/index.html" },
    { "source": "/about", "destination": "/design/about.html" },
    { "source": "/about.html", "destination": "/design/about.html" },
    { "source": "/publishing", "destination": "/design/publishing.html" },
    { "source": "/publishing.html", "destination": "/design/publishing.html" },
    { "source": "/lounge", "destination": "/design/lounge.html" },
    { "source": "/lounge.html", "destination": "/design/lounge.html" },
    { "source": "/artists", "destination": "/design/artists.html" },
    { "source": "/artists.html", "destination": "/design/artists.html" },
    { "source": "/portfolio", "destination": "/design/portfolio.html" },
    { "source": "/portfolio.html", "destination": "/design/portfolio.html" },
    { "source": "/contact", "destination": "/design/contact.html" },
    { "source": "/contact.html", "destination": "/design/contact.html" },
    { "source": "/css/:path*", "destination": "/design/css/:path*" },
    { "source": "/js/:path*", "destination": "/design/js/:path*" },
    { "source": "/assets/:path*", "destination": "/design/assets/:path*" }
  ],
  "headers": [
    {
      "source": "/design/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
